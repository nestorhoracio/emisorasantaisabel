---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Schedule from '../components/Schedule.astro';
import Timeline from '../components/Timeline.astro';
import YouTube from '../components/YouTube.astro';
---

<Layout>
  <Hero />

  <hr class="divider" />
  <Schedule />

  <hr class="divider" />
  <Timeline />

  <hr class="divider" />
  <YouTube />

  <hr class="divider" />

  <!-- Contacto — placeholder -->
  <section class="section" id="contacto">
    <span class="sec-label">Contacto</span>
    <h2 class="sec-title">Hablemos</h2>
    <p class="sec-body">
      Dedicatorias, auspicios, consultas y todo lo que quieras hacernos llegar.
    </p>

    <div class="contact-grid">
      <div class="contact-card">
        <p class="contact-label">Teléfono</p>
        <p class="contact-val">4664 5124 / 4664 3408</p>
      </div>
      <div class="contact-card">
        <p class="contact-label">Celular</p>
        <p class="contact-val">092 104 995</p>
      </div>
      <div class="contact-card">
        <p class="contact-label">Email</p>
        <p class="contact-val">
          <a href="mailto:santaisabelfm@vera.com.uy">santaisabelfm@vera.com.uy</a>
        </p>
      </div>
      <div class="contact-card">
        <p class="contact-label">Dirección</p>
        <p class="contact-val">Baltasar Brum 753, Paso de los Toros</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1px;
    background: var(--faint);
    border: 1px solid var(--faint);
    border-radius: 4px;
    overflow: hidden;
    margin-top: 2.5rem;
  }

  .contact-card {
    background: var(--surface);
    padding: 1.25rem;
  }

  .contact-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--blue-bright);
    margin-bottom: 6px;
  }

  .contact-val {
    font-size: 14px;
    color: var(--text);
    font-weight: 500;
  }

  .contact-val a {
    color: var(--text);
  }
</style>
