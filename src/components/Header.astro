---
// Header.astro — fijo arriba, logo + nav + theme switcher
---

<header class="header">
  <div class="header-inner">

    <!-- Logo -->
    <a href="/" class="logo-link" aria-label="Santa Isabel FM — Inicio">
      <img src="/logo.jpg" alt="Santa Isabel FM 100.1" class="logo-img" />
    </a>

    <!-- Nav -->
    <nav class="nav" aria-label="Navegación principal">
      <a href="#programacion" class="nav-link">Programación</a>
      <a href="#equipo"          class="nav-link">Equipo</a>
<a href="#patrocinadores"  class="nav-link">Patrocinadores</a>
      <a href="#historia"     class="nav-link">Historia</a>
      <a href="#videos"       class="nav-link">Videos</a>
      <a href="#contacto"     class="nav-link">Contacto</a>
    </nav>
<!-- Botón hamburguesa -->
<button class="hamburger" id="hamburger" aria-label="Menú">
  <span></span>
  <span></span>
  <span></span>
</button>

<!-- Menú mobile -->
<div class="mobile-menu" id="mobile-menu">
  <a href="#programacion" class="mobile-link">Programación</a>
  <a href="#historia"     class="mobile-link">Historia</a>
  <a href="#equipo"       class="mobile-link">Equipo</a>
  <a href="#videos"       class="mobile-link">Videos</a>
  <a href="#patrocinadores" class="mobile-link">Patrocinadores</a>
  <a href="#contacto"     class="mobile-link">Contacto</a>
</div>
    <!-- Controles: tema + escuchar -->
    <div class="header-actions">

      <!-- CTA mobile-friendly -->
      <a href="#player" class="btn-listen" onclick="window.__sifmPlay && window.__sifmPlay(); return false;">
        ▶ En vivo
      </a>
    </div>

  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--header-h);
    background: var(--surface);
    border-bottom: 1px solid var(--faint);
    z-index: 200;
    transition: background 0.3s ease;
  }

  /* Línea de acento azul abajo del header */
  .header::after {
    content: '';
    position: absolute;
    bottom: -1px; left: 0;
    width: 80px; height: 2px;
    background: linear-gradient(90deg, var(--blue), var(--red));
  }

  .header-inner {
    max-width: 1100px;
    margin: 0 auto;
    height: 100%;
    display: flex;
    align-items: center;
    padding: 0 1.25rem;
    gap: 1.5rem;
  }

  /* Logo */
  .logo-link { flex-shrink: 0; display: flex; align-items: center; }

  .logo-img {
    height: 40px;
    width: auto;
    object-fit: contain;
    border-radius: 3px;
  }

  /* Nav */
  .nav {
    display: flex;
    gap: 0;
    flex: 1;
    padding-left: 1rem;
  }

  .nav-link {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 0 .9rem;
    height: var(--header-h);
    display: flex;
    align-items: center;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
    text-decoration: none;
  }

  .nav-link:hover {
    color: var(--text);
    border-bottom-color: var(--blue);
    text-decoration: none;
  }

  /* Acciones */
  .header-actions {
    display: flex;
    align-items: center;
    gap: .75rem;
    margin-left: auto;
  }

  /* Theme button */
  .theme-btn {
    width: 36px; height: 36px;
    border-radius: 50%;
    border: 1px solid var(--faint);
    background: var(--surface-2);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    transition: background 0.2s, border-color 0.2s;
    color: var(--text-muted);
  }

  .theme-btn:hover {
    background: var(--surface-3);
    border-color: var(--blue);
    color: var(--text);
  }

  /* CTA */
  .btn-listen {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: var(--blue);
    color: #f0eeea;
    padding: 8px 16px;
    border-radius: 3px;
    text-decoration: none;
    transition: background 0.2s;
    white-space: nowrap;
  }

  .btn-listen:hover { background: var(--blue-bright); text-decoration: none; }

  /* Mobile: ocultar nav completa */
  @media (max-width: 640px) {
    .nav { display: none; }
    .btn-listen { display: none; }
  }
  /* Hamburguesa */
.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 4px;
  margin-left: .5rem;
}

.hamburger span {
  display: block;
  width: 22px; height: 2px;
  background: var(--text);
  border-radius: 2px;
  transition: all 0.2s;
}

/* Menú mobile */
.mobile-menu {
  display: none;
  position: fixed;
  top: var(--header-h);
  left: 0; right: 0;
  background: var(--surface);
  border-bottom: 1px solid var(--faint);
  flex-direction: column;
  padding: 1rem 0;
  z-index: 199;
}

.mobile-menu.open { display: flex; }

.mobile-link {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 16px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-muted);
  padding: .85rem 1.5rem;
  text-decoration: none;
  border-bottom: 1px solid var(--surface-2);
  transition: color 0.2s, background 0.2s;
}

.mobile-link:hover {
  color: var(--text);
  background: var(--surface-2);
  text-decoration: none;
}

@media (max-width: 640px) {
  .hamburger { display: flex; }
}
</style>
<script>
// Menú mobile
const hamburger   = document.getElementById('hamburger')!;
const mobileMenu  = document.getElementById('mobile-menu')!;

hamburger.addEventListener('click', () => {
  mobileMenu.classList.toggle('open');
});

// Cerrar al hacer click en un link
mobileMenu.querySelectorAll('.mobile-link').forEach(link => {
  link.addEventListener('click', () => {
    mobileMenu.classList.remove('open');
  });
});
</script>